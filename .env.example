# ==================== X / Twitter Authentication ====================
# XHS full cookie header (export from logged-in browser session)
COOKIES=

# Option A (recommended): set token pair directly
TWITTER_AUTH_TOKEN=
TWITTER_CT0=

# Option B: set full cookie header and let config auto-extract auth_token/ct0
TWITTER_COOKIE=
