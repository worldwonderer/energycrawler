# EnergyCrawler full environment template
# Core first, advanced later.
# Tip:
#   - beginner: copy .env.quickstart.example
#   - advanced tuning: keep this file as reference

# ==================== Core runtime ====================
PLATFORM=xhs
CRAWLER_TYPE=search
LOGIN_TYPE=cookie
KEYWORDS=新能源
HEADLESS=false
SAVE_DATA_OPTION=json
SAVE_DATA_PATH=
ENERGY_SERVICE_ADDRESS=localhost:50051

# Conservative defaults
CRAWLER_MAX_NOTES_COUNT=5
MAX_CONCURRENCY_NUM=1
CRAWLER_MAX_SLEEP_SEC=10

# ==================== Core auth ====================
# XHS full cookie header (optional if synced from Energy)
COOKIES=

# X / Twitter auth (required for PLATFORM=x)
TWITTER_AUTH_TOKEN=
TWITTER_CT0=

# ==================== Advanced auth (optional) ====================
# Alternative to token pair above
TWITTER_COOKIE=

# CookieCloud sync
COOKIECLOUD_ENABLED=false
COOKIECLOUD_FORCE_SYNC=false
COOKIECLOUD_SERVER=
COOKIECLOUD_UUID=
COOKIECLOUD_PASSWORD=
COOKIECLOUD_TIMEOUT_SEC=10

# Auth Watchdog
AUTH_WATCHDOG_ENABLED=true
AUTH_WATCHDOG_MAX_RETRIES=1
AUTH_WATCHDOG_RETRY_INTERVAL_SEC=2
AUTH_WATCHDOG_FORCE_COOKIECLOUD_SYNC=true
AUTH_WATCHDOG_MAX_RUNTIME_RECOVERIES=1

# ==================== Advanced crawler safety ====================
CRAWLER_HARD_MAX_NOTES_COUNT=20
CRAWLER_HARD_MAX_CONCURRENCY=2
CRAWLER_MIN_SLEEP_SEC=6
CRAWLER_SLEEP_JITTER_SEC=1.2
CRAWLER_RETRY_BASE_DELAY_SEC=2
CRAWLER_RETRY_MAX_DELAY_SEC=30

# XHS signature canary
XHS_SIGNATURE_CANARY_ENABLED=false
XHS_SIGNATURE_CANARY_TIMEOUT_SEC=8
XHS_SIGNATURE_CANARY_BASELINE_PATH=
XHS_SIGNATURE_SESSION_TTL_SEC=1800
XHS_SIGNATURE_FAILURE_THRESHOLD=3

# ==================== Storage backends (optional) ====================
# MySQL
MYSQL_DB_HOST=localhost
MYSQL_DB_PORT=3306
MYSQL_DB_USER=root
MYSQL_DB_PWD=123456
MYSQL_DB_NAME=energycrawler

# MongoDB
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USER=
MONGODB_PWD=
MONGODB_DB_NAME=energycrawler

# PostgreSQL
POSTGRES_DB_HOST=localhost
POSTGRES_DB_PORT=5432
POSTGRES_DB_USER=postgres
POSTGRES_DB_PWD=123456
POSTGRES_DB_NAME=energycrawler

# Redis (if needed by your own extensions)
REDIS_DB_HOST=127.0.0.1
REDIS_DB_PORT=6379
REDIS_DB_PWD=123456
REDIS_DB_NUM=0
