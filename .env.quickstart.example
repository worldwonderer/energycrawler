# Minimal setup for first run

# Core runtime defaults
PLATFORM=xhs
CRAWLER_TYPE=search
LOGIN_TYPE=cookie
KEYWORDS=新能源
HEADLESS=false
ENERGY_SERVICE_ADDRESS=localhost:50051

# Safe crawl defaults for small-batch runs
CRAWLER_MAX_NOTES_COUNT=3
MAX_CONCURRENCY_NUM=1
CRAWLER_MAX_SLEEP_SEC=12

# Auth material
# XHS cookie header (optional if injected from Energy auth flow)
COOKIES=

# X/Twitter auth (required for platform=x)
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
# Or use full cookie and auto-extract auth_token/ct0
TWITTER_COOKIE=

# Optional: CookieCloud auto sync (when enabled, crawler will pull cookies before running)
COOKIECLOUD_ENABLED=false
COOKIECLOUD_SERVER=
COOKIECLOUD_UUID=
COOKIECLOUD_PASSWORD=

# Optional runtime checks
XHS_SIGNATURE_CANARY_ENABLED=false
