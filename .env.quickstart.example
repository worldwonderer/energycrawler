# EnergyCrawler core environment template (minimal / beginner friendly)
# Copy to .env and fill only what you need.
# For advanced tuning, run: uv run energycrawler config env --mode advanced

# -------- Core runtime --------
PLATFORM=xhs
CRAWLER_TYPE=search
LOGIN_TYPE=cookie
KEYWORDS=新能源
HEADLESS=false
SAVE_DATA_OPTION=json
ENERGY_SERVICE_ADDRESS=localhost:50051

# -------- Safe defaults --------
CRAWLER_MAX_NOTES_COUNT=5
MAX_CONCURRENCY_NUM=1
CRAWLER_MAX_SLEEP_SEC=10

# -------- Authentication --------
# XHS (optional if you sync login from Energy)
COOKIES=

# X / Twitter (required only when PLATFORM=x)
TWITTER_AUTH_TOKEN=
TWITTER_CT0=
